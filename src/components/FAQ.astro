---
const faqs = [
  {
    question: "¿Necesito experiencia previa para unirme?",
    answer: "¡Para nada! ForzaBox está diseñado para todos los niveles. Nuestros coaches adaptan cada entrenamiento a tu condición física actual y te guiarán paso a paso."
  },
  {
    question: "¿Qué incluye la membresía?",
    answer: "Acceso ilimitado a todas nuestras clases, asesoría nutricional básica, seguimiento personalizado y acceso a nuestra comunidad exclusiva de miembros."
  },
  {
    question: "¿Tienen clase de prueba gratis?",
    answer: "¡Sí! Ofrecemos una clase de prueba completamente GRATIS para que conozcas nuestras instalaciones, equipo y metodología. Contáctanos para agendar."
  },
  {
    question: "¿Cuáles son los horarios de las clases?",
    answer: "Tenemos clases de lunes a viernes desde las 6:00 AM hasta las 7:30 PM, y los sábados de 7:00 AM a 9:00 AM. Consulta nuestra sección de horarios para más detalles."
  },
  {
    question: "¿Qué debo llevar a mi primera clase?",
    answer: "Ropa cómoda para entrenar, zapatos deportivos, una botella de agua y una toalla. Nosotros proporcionamos todo el equipo necesario."
  },
  {
    question: "¿Hay estacionamiento disponible?",
    answer: "Sí, contamos con estacionamiento gratuito para todos nuestros miembros. También estamos cerca de transporte público."
  },
  {
    question: "¿Ofrecen planes personalizados?",
    answer: "¡Por supuesto! Ofrecemos entrenamientos personalizados one-on-one con nuestros coaches certificados. Contáctanos para conocer los planes disponibles."
  },
  {
    question: "¿Cómo puedo cancelar o congelar mi membresía?",
    answer: "Puedes congelar tu membresía hasta por 30 días al año por razones médicas o viaje. Para cancelaciones, requerimos un aviso de 15 días. Contáctanos para más información."
  }
];

const phoneNumber = '50683131641';
const message = encodeURIComponent('Hola, me interesa saber más sobre ForzaBox');
const faqWhatsappUrl = `https://wa.me/${phoneNumber}?text=${message}`;
---

<section id="faq" class="faq-section">
  <div class="container">
    <div class="faq-header">
      <h2>Preguntas Frecuentes</h2>
      <p>Encuentra respuestas a las dudas más comunes</p>
    </div>

    <div class="faq-list">
      {faqs.map((faq, index) => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{faq.question}</span>
            <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="faq-cta">
      <div class="faq-cta-content">
        <h3>¿No encontraste lo que buscabas?</h3>
        <p>Estamos aquí para ayudarte</p>
      </div>
      <div class="cta-buttons">
        <a href="#contact" class="btn btn-primary">
          <span>Enviar Mensaje</span>
          <svg class="btn-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
        <a href={faqWhatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">WhatsApp</a>
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: var(--spacing-xl) 0;
    background: linear-gradient(
      to bottom,
      var(--accent-white) 0%,
      var(--gray-lighter) 50%,
      var(--accent-white) 100%
    );
    position: relative;
  }

  .faq-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 400px;
    background: radial-gradient(
      ellipse at top,
      rgba(0, 229, 204, 0.05) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
    position: relative;
    z-index: 1;
  }

  .faq-header {
    text-align: center;
    margin-bottom: 3rem;
    opacity: 0;
    transform: translateY(-20px);
  }

  .faq-header.animate {
    animation: fadeInDown 0.8s ease forwards;
  }

  .faq-header h2 {
    font-size: clamp(2rem, 5vw, 2.5rem);
    margin-bottom: 0.5rem;
    font-weight: 800;
    color: var(--dark-accent);
  }

  .faq-header p {
    font-size: var(--text-lg);
    color: var(--gray-dark);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    opacity: 0;
    transform: translateY(20px);
  }

  .faq-list.animate {
    animation: fadeInUp 0.8s ease forwards 0.2s;
  }

  .faq-item {
    background: var(--accent-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    box-shadow: var(--shadow-md);
  }

  .faq-item:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-cyan);
  }

  .faq-item[open] {
    background: linear-gradient(135deg, rgba(0, 229, 204, 0.05), rgba(0, 229, 204, 0.02));
    border-color: var(--primary-cyan);
  }

  .faq-question {
    padding: 1.5rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
    font-size: var(--text-lg);
    color: var(--dark-accent);
    transition: all 0.3s ease;
    user-select: none;
  }

  .faq-question:hover {
    background: var(--gray-lighter);
  }

  .faq-icon {
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 1rem;
    color: var(--primary-cyan);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 1.5rem 1.5rem;
    color: var(--gray-dark);
    line-height: 1.7;
    animation: slideDown 0.3s ease forwards;
  }

  .faq-answer p {
    margin: 0;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scaleIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .faq-cta {
    margin-top: 4rem;
    padding: 2.75rem 2rem;
    background: linear-gradient(135deg, var(--dark-accent) 0%, var(--dark-bg) 100%);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(0, 229, 204, 0.16);
    box-shadow: 0 14px 36px rgba(22, 27, 35, 0.35);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: scale(0.95);
  }

  .faq-cta.animate {
    animation: scaleIn 0.6s ease forwards 0.4s;
  }

  .faq-cta::before {
    content: '';
    position: absolute;
    top: -55%;
    right: -40%;
    width: 180%;
    height: 180%;
    background: radial-gradient(circle, rgba(0, 229, 204, 0.14) 0%, transparent 62%);
    animation: rotateBg 18s linear infinite;
  }

  .faq-cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(110deg, rgba(255, 255, 255, 0.05), transparent 32%, transparent 68%, rgba(0, 229, 204, 0.08));
    pointer-events: none;
  }

  .faq-cta-content {
    position: relative;
    z-index: 1;
  }

  .faq-cta h3 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--accent-white);
    margin-bottom: 0.4rem;
    font-weight: 800;
    text-wrap: balance;
  }

  .faq-cta p {
    color: var(--gray-light);
    font-size: 1.02rem;
    margin: 0;
    opacity: 0.95;
  }

  .cta-buttons {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.95rem 1.85rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 1px solid transparent;
    font-size: var(--text-base);
    min-width: 190px;
    position: relative;
    overflow: hidden;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--primary-cyan), #00d3bc);
    color: var(--dark-accent);
    box-shadow: 0 8px 24px rgba(0, 229, 204, 0.32);
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
    transition: left 0.5s ease;
  }

  .btn-primary:hover::before {
    left: 100%;
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, var(--cyan-light), var(--primary-cyan));
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0, 229, 204, 0.42);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.08);
    color: var(--accent-white);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }

  .btn-secondary:hover {
    background: #25D366;
    border-color: #25D366;
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(37, 211, 102, 0.45);
  }

  .btn-arrow {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(3px);
  }

  @keyframes rotateBg {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @media (max-width: 768px) {
    .faq-section {
      padding: var(--spacing-lg) 0;
    }

    .container {
      padding: 0 1rem;
    }

    .faq-header {
      margin-bottom: 2rem;
    }

    .faq-header h2 {
      font-size: 2rem;
    }

    .faq-question {
      padding: 1.25rem;
      font-size: var(--text-base);
    }

    .faq-answer {
      padding: 0 1.25rem 1.25rem;
    }

    .faq-cta {
      padding: 2.4rem 1.35rem;
      margin-top: 3rem;
    }

    .cta-buttons {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      min-width: 0;
    }
  }

  @media (max-width: 480px) {
    .faq-section {
      padding: var(--spacing-md) 0;
    }

    .container {
      padding: 0 1rem;
    }

    .faq-header h2 {
      font-size: 1.75rem;
    }

    .faq-header p {
      font-size: var(--text-base);
    }

    .faq-question {
      padding: 1rem;
      font-size: var(--text-sm);
    }

    .faq-answer {
      padding: 0 1rem 1rem;
      font-size: var(--text-sm);
    }

    .faq-cta {
      padding: 2.1rem 1rem;
    }

    .faq-cta h3 {
      font-size: 1.5rem;
    }

    .faq-cta p {
      font-size: var(--text-base);
    }

    .btn {
      padding: 0.875rem 1.5rem;
      font-size: var(--text-sm);
      width: 100%;
      min-width: 0;
    }
  }
</style>

<script>
  function initFaqAnimations() {
    const header = document.querySelector('.faq-section .faq-header');
    const list = document.querySelector('.faq-section .faq-list');
    const cta = document.querySelector('.faq-section .faq-cta');

    const targets = [header, list, cta].filter(Boolean) as Element[];

    if (!('IntersectionObserver' in window)) {
      targets.forEach(target => target.classList.add('animate'));
      return;
    }

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('animate');
          obs.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.2,
      rootMargin: '0px 0px -10% 0px'
    });

    targets.forEach(target => observer.observe(target));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFaqAnimations);
  } else {
    initFaqAnimations();
  }
</script>